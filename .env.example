# =====================================================================
# Festival Karakter Pelajar Universitas STEKOM — Environment
# Copy this file to .env.local and fill in your Supabase project values.
# =====================================================================

# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Project Settings -> API -> service_role)
# SERVER ONLY — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (for SEO / Open Graph). e.g. https://fkp.stekom.ac.id
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Salt for hashing client IPs (anti-cheat). Use any long random string.
# SERVER ONLY.
IP_HASH_SALT=change-me-to-a-long-random-string

# URL Apps Script Web App untuk cari password peserta by nama.
# Lihat scripts/appscript-cari-password.gs untuk cara deploy.
NEXT_PUBLIC_PASSWORD_LOOKUP_URL=
